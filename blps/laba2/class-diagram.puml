  class AuthenticationManager <<external>>
  class PlatformTransactionManager <<external>>
  class TransactionTemplate <<external>>
  class SecurityFilterChain <<external>>
  class UserDetailsService <<external>>
  class OncePerRequestFilter <<external>>
}

