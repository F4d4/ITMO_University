<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="UserGetDefs">
  <process id="user-get-process" name="[GET] Пользователь по ID" isExecutable="true">

    <startEvent id="start" name="Начало">
      <extensionElements>
        <camunda:executionListener event="start" delegateExpression="${resolveJwtUserDelegate}"/>
        <camunda:formData>
          <camunda:formField id="jwtToken" label="JWT-токен" type="string">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="targetUserId" label="ID пользователя" type="long">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
      <outgoing>sf_start</outgoing>
    </startEvent>

    <serviceTask id="loadUser" name="Загрузить пользователя"
                 camunda:delegateExpression="${loadUserByIdDelegate}">
      <incoming>sf_start</incoming>
      <outgoing>sf_loaded</outgoing>
    </serviceTask>

    <userTask id="showUserDetail" name="Просмотр пользователя"
              camunda:assignee="${assignee}">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="userJson" label="Пользователь (JSON)" type="string"/>
        </camunda:formData>
      </extensionElements>
      <incoming>sf_loaded</incoming>
      <outgoing>sf_end</outgoing>
    </userTask>

    <endEvent id="end" name="Просмотр завершён">
      <incoming>sf_end</incoming>
    </endEvent>

    <sequenceFlow id="sf_start" sourceRef="start" targetRef="loadUser"/>
    <sequenceFlow id="sf_loaded" sourceRef="loadUser" targetRef="showUserDetail"/>
    <sequenceFlow id="sf_end" sourceRef="showUserDetail" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="user-get-process">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="160" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="loadUser_di" bpmnElement="loadUser">
        <omgdc:Bounds x="250" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="showUserDetail_di" bpmnElement="showUserDetail">
        <omgdc:Bounds x="410" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="570" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf_start_di" bpmnElement="sf_start">
        <omgdi:waypoint x="196" y="120"/>
        <omgdi:waypoint x="250" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_loaded_di" bpmnElement="sf_loaded">
        <omgdi:waypoint x="350" y="120"/>
        <omgdi:waypoint x="410" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_end_di" bpmnElement="sf_end">
        <omgdi:waypoint x="510" y="120"/>
        <omgdi:waypoint x="570" y="120"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
