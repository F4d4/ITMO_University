<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="ModerationPendingMethodsDefs">
  <process id="moderation-pending-methods-process" name="[GET] Очередь модерации методов" isExecutable="true">

    <startEvent id="start" name="Получена заявка на модерацию">
      <outgoing>sf_start</outgoing>
    </startEvent>

    <serviceTask id="loadPendingMethods" name="Загрузить очередь методов"
                 camunda:delegateExpression="${loadPendingMethodsDelegate}">
      <incoming>sf_start</incoming>
      <incoming>sf_refresh</incoming>
      <outgoing>sf_loaded</outgoing>
    </serviceTask>

    <userTask id="showMethodsQueue" name="Очередь модерации методов монетизации"
              camunda:formKey="embedded:app:forms/pending-methods-list.html"
              camunda:candidateGroups="moderator">
      <incoming>sf_loaded</incoming>
      <outgoing>sf_to_gw</outgoing>
    </userTask>

    <exclusiveGateway id="refreshGw" name="Обновить?" default="sf_close">
      <incoming>sf_to_gw</incoming>
      <outgoing>sf_refresh</outgoing>
      <outgoing>sf_close</outgoing>
    </exclusiveGateway>

    <endEvent id="end" name="Просмотр завершён">
      <incoming>sf_close</incoming>
    </endEvent>

    <sequenceFlow id="sf_start" sourceRef="start" targetRef="loadPendingMethods"/>
    <sequenceFlow id="sf_loaded" sourceRef="loadPendingMethods" targetRef="showMethodsQueue"/>
    <sequenceFlow id="sf_to_gw" sourceRef="showMethodsQueue" targetRef="refreshGw"/>
    <sequenceFlow id="sf_refresh" name="Обновить" sourceRef="refreshGw" targetRef="loadPendingMethods">
      <conditionExpression xsi:type="tFormalExpression">${refresh == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_close" name="Закрыть" sourceRef="refreshGw" targetRef="end"/>

  </process>
</definitions>
