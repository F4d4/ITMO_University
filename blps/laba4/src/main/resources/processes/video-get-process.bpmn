<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="VideoGetDefs">
  <process id="video-get-process" name="[GET] Видео по ID" isExecutable="true">

    <startEvent id="start" name="Начало">
      <outgoing>sf_start</outgoing>
    </startEvent>

    <serviceTask id="loadVideo" name="Загрузить видео"
                 camunda:delegateExpression="${loadVideoByIdDelegate}">
      <incoming>sf_start</incoming>
      <outgoing>sf_loaded</outgoing>
    </serviceTask>

    <userTask id="showVideoDetail" name="Просмотр видео"
              camunda:formKey="embedded:app:forms/video-detail.html"
              camunda:assignee="${assignee}">
      <incoming>sf_loaded</incoming>
      <outgoing>sf_end</outgoing>
    </userTask>

    <endEvent id="end" name="Просмотр завершён">
      <incoming>sf_end</incoming>
    </endEvent>

    <sequenceFlow id="sf_start" sourceRef="start" targetRef="loadVideo"/>
    <sequenceFlow id="sf_loaded" sourceRef="loadVideo" targetRef="showVideoDetail"/>
    <sequenceFlow id="sf_end" sourceRef="showVideoDetail" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="video-get-process">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="160" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="loadVideo_di" bpmnElement="loadVideo">
        <omgdc:Bounds x="250" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="showVideoDetail_di" bpmnElement="showVideoDetail">
        <omgdc:Bounds x="410" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="570" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf_start_di" bpmnElement="sf_start">
        <omgdi:waypoint x="196" y="120"/>
        <omgdi:waypoint x="250" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_loaded_di" bpmnElement="sf_loaded">
        <omgdi:waypoint x="350" y="120"/>
        <omgdi:waypoint x="410" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_end_di" bpmnElement="sf_end">
        <omgdi:waypoint x="510" y="120"/>
        <omgdi:waypoint x="570" y="120"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
