<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="VideoPublishDefinitions">

  <process id="video-publish-process" name="Публикация видео" isExecutable="true">

    <startEvent id="startPublish" name="Запрос на публикацию">
      <extensionElements>
        <camunda:executionListener event="start" delegateExpression="${resolveJwtUserDelegate}"/>
        <camunda:formData>
          <camunda:formField id="jwtToken" label="JWT-токен" type="string">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="videoId" label="ID видео" type="long">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
      <outgoing>flow_start_to_configure</outgoing>
    </startEvent>

    <userTask id="configurePublication" name="Настроить параметры публикации"
              camunda:assignee="${uploaderId}">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="audienceType" label="Возрастная аудитория" type="enum" defaultValue="ALL_AGES">
            <camunda:value id="ALL_AGES" name="Для всех возрастов"/>
            <camunda:value id="ADULTS_ONLY" name="Только для взрослых"/>
          </camunda:formField>
          <camunda:formField id="accessType" label="Тип доступа" type="enum" defaultValue="PUBLIC">
            <camunda:value id="PUBLIC" name="Публичный"/>
            <camunda:value id="PRIVATE" name="Приватный"/>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
      <incoming>flow_start_to_configure</incoming>
      <outgoing>flow_configure_to_pending</outgoing>
    </userTask>

    <serviceTask id="setPendingStatus" name="Установить статус: ОЖИДАЕТ ПУБЛИКАЦИИ"
                 camunda:delegateExpression="${setPendingPublicationDelegate}">
      <incoming>flow_configure_to_pending</incoming>
      <outgoing>flow_pending_to_moderate</outgoing>
    </serviceTask>

    <serviceTask id="autoModerateDescription" name="Автомодерация описания"
                 camunda:delegateExpression="${autoModeratePublishDelegate}">
      <incoming>flow_pending_to_moderate</incoming>
      <outgoing>flow_moderate_to_gateway</outgoing>
    </serviceTask>

    <exclusiveGateway id="autoApprovedGateway" name="Автоодобрено?">
      <incoming>flow_moderate_to_gateway</incoming>
      <outgoing>flow_auto_approved</outgoing>
      <outgoing>flow_needs_manual_review</outgoing>
    </exclusiveGateway>

    <userTask id="reviewByModerator" name="Ручная проверка модератором"
              camunda:candidateGroups="moderator">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="moderatorApproved" label="Одобрить публикацию?" type="boolean" defaultValue="true"/>
          <camunda:formField id="rejectionReason" label="Причина отклонения" type="string"/>
        </camunda:formData>
      </extensionElements>
      <incoming>flow_needs_manual_review</incoming>
      <outgoing>flow_review_to_gateway</outgoing>
    </userTask>

    <exclusiveGateway id="moderatorDecisionGateway" name="Решение модератора">
      <incoming>flow_review_to_gateway</incoming>
      <outgoing>flow_moderator_approved</outgoing>
      <outgoing>flow_moderator_rejected</outgoing>
    </exclusiveGateway>

    <subProcess id="publishSubProcess" name="Публикация видео">
      <incoming>flow_auto_approved</incoming>
      <incoming>flow_moderator_approved</incoming>
      <outgoing>flow_subprocess_to_published</outgoing>

      <startEvent id="publishStart">
        <outgoing>flow_ps_to_change_status</outgoing>
      </startEvent>

      <serviceTask id="changeStatusPublished" name="Изменить статус на ОПУБЛИКОВАНО"
                   camunda:delegateExpression="${changeVideoStatusPublishedDelegate}">
        <incoming>flow_ps_to_change_status</incoming>
        <outgoing>flow_ps_to_save_params</outgoing>
      </serviceTask>

      <serviceTask id="savePublishParams" name="Сохранить параметры публикации"
                   camunda:delegateExpression="${savePublicationParamsDelegate}">
        <incoming>flow_ps_to_save_params</incoming>
        <outgoing>flow_ps_to_copy_file</outgoing>
      </serviceTask>

      <serviceTask id="copyToPublished" name="Копировать файл в опубликованные"
                   camunda:delegateExpression="${publishVideoFileDelegate}">
        <incoming>flow_ps_to_copy_file</incoming>
        <outgoing>flow_ps_to_end</outgoing>
      </serviceTask>

      <endEvent id="publishSubEnd">
        <incoming>flow_ps_to_end</incoming>
      </endEvent>

      <sequenceFlow id="flow_ps_to_change_status" sourceRef="publishStart" targetRef="changeStatusPublished"/>
      <sequenceFlow id="flow_ps_to_save_params" sourceRef="changeStatusPublished" targetRef="savePublishParams"/>
      <sequenceFlow id="flow_ps_to_copy_file" sourceRef="savePublishParams" targetRef="copyToPublished"/>
      <sequenceFlow id="flow_ps_to_end" sourceRef="copyToPublished" targetRef="publishSubEnd"/>
    </subProcess>

    <serviceTask id="rejectPublication" name="Отклонить публикацию"
                 camunda:delegateExpression="${rejectPublicationDelegate}">
      <incoming>flow_moderator_rejected</incoming>
      <outgoing>flow_reject_to_end</outgoing>
    </serviceTask>

    <endEvent id="videoPublished" name="Видео опубликовано">
      <incoming>flow_subprocess_to_published</incoming>
    </endEvent>

    <endEvent id="publicationRejected" name="Публикация отклонена">
      <incoming>flow_reject_to_end</incoming>
    </endEvent>

    <sequenceFlow id="flow_start_to_configure" sourceRef="startPublish" targetRef="configurePublication"/>
    <sequenceFlow id="flow_configure_to_pending" sourceRef="configurePublication" targetRef="setPendingStatus"/>
    <sequenceFlow id="flow_pending_to_moderate" sourceRef="setPendingStatus" targetRef="autoModerateDescription"/>
    <sequenceFlow id="flow_moderate_to_gateway" sourceRef="autoModerateDescription" targetRef="autoApprovedGateway"/>
    <sequenceFlow id="flow_auto_approved" name="Автоодобрено" sourceRef="autoApprovedGateway" targetRef="publishSubProcess">
      <conditionExpression xsi:type="tFormalExpression">${autoApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_needs_manual_review" name="Требует проверки" sourceRef="autoApprovedGateway" targetRef="reviewByModerator">
      <conditionExpression xsi:type="tFormalExpression">${autoApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_review_to_gateway" sourceRef="reviewByModerator" targetRef="moderatorDecisionGateway"/>
    <sequenceFlow id="flow_moderator_approved" name="Одобрено" sourceRef="moderatorDecisionGateway" targetRef="publishSubProcess">
      <conditionExpression xsi:type="tFormalExpression">${moderatorApproved == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_moderator_rejected" name="Отклонено" sourceRef="moderatorDecisionGateway" targetRef="rejectPublication">
      <conditionExpression xsi:type="tFormalExpression">${moderatorApproved == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_subprocess_to_published" sourceRef="publishSubProcess" targetRef="videoPublished"/>
    <sequenceFlow id="flow_reject_to_end" sourceRef="rejectPublication" targetRef="publicationRejected"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="video-publish-process">
      <bpmndi:BPMNShape id="startPublish_di" bpmnElement="startPublish">
        <omgdc:Bounds x="150" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="configurePublication_di" bpmnElement="configurePublication">
        <omgdc:Bounds x="240" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="setPendingStatus_di" bpmnElement="setPendingStatus">
        <omgdc:Bounds x="390" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="autoModerateDescription_di" bpmnElement="autoModerateDescription">
        <omgdc:Bounds x="540" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="autoApprovedGateway_di" bpmnElement="autoApprovedGateway" isMarkerVisible="true">
        <omgdc:Bounds x="695" y="135" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="publishSubProcess_di" bpmnElement="publishSubProcess" isExpanded="false">
        <omgdc:Bounds x="900" y="120" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="videoPublished_di" bpmnElement="videoPublished">
        <omgdc:Bounds x="1080" y="142" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="reviewByModerator_di" bpmnElement="reviewByModerator">
        <omgdc:Bounds x="670" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="moderatorDecisionGateway_di" bpmnElement="moderatorDecisionGateway" isMarkerVisible="true">
        <omgdc:Bounds x="820" y="275" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="rejectPublication_di" bpmnElement="rejectPublication">
        <omgdc:Bounds x="795" y="380" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="publicationRejected_di" bpmnElement="publicationRejected">
        <omgdc:Bounds x="960" y="402" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start_to_configure_di" bpmnElement="flow_start_to_configure">
        <omgdi:waypoint x="186" y="160"/>
        <omgdi:waypoint x="240" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_configure_to_pending_di" bpmnElement="flow_configure_to_pending">
        <omgdi:waypoint x="340" y="160"/>
        <omgdi:waypoint x="390" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_pending_to_moderate_di" bpmnElement="flow_pending_to_moderate">
        <omgdi:waypoint x="490" y="160"/>
        <omgdi:waypoint x="540" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_moderate_to_gateway_di" bpmnElement="flow_moderate_to_gateway">
        <omgdi:waypoint x="640" y="160"/>
        <omgdi:waypoint x="695" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_auto_approved_di" bpmnElement="flow_auto_approved">
        <omgdi:waypoint x="745" y="160"/>
        <omgdi:waypoint x="900" y="160"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_needs_manual_review_di" bpmnElement="flow_needs_manual_review">
        <omgdi:waypoint x="720" y="185"/>
        <omgdi:waypoint x="720" y="260"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_review_to_gateway_di" bpmnElement="flow_review_to_gateway">
        <omgdi:waypoint x="770" y="300"/>
        <omgdi:waypoint x="820" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_moderator_approved_di" bpmnElement="flow_moderator_approved">
        <omgdi:waypoint x="870" y="300"/>
        <omgdi:waypoint x="950" y="300"/>
        <omgdi:waypoint x="950" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_moderator_rejected_di" bpmnElement="flow_moderator_rejected">
        <omgdi:waypoint x="845" y="325"/>
        <omgdi:waypoint x="845" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_reject_to_end_di" bpmnElement="flow_reject_to_end">
        <omgdi:waypoint x="895" y="420"/>
        <omgdi:waypoint x="960" y="420"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_subprocess_to_published_di" bpmnElement="flow_subprocess_to_published">
        <omgdi:waypoint x="1000" y="160"/>
        <omgdi:waypoint x="1080" y="160"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
