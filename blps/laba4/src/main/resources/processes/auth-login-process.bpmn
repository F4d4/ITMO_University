<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="AuthLoginDefs">
  <process id="auth-login-process" name="[POST] Авторизация пользователя" isExecutable="true">

    <startEvent id="start" name="Начало авторизации"
                camunda:formKey="embedded:app:forms/login-form.html">
      <outgoing>sf1</outgoing>
    </startEvent>

    <serviceTask id="loginUser" name="Авторизовать пользователя"
                 camunda:delegateExpression="${loginUserDelegate}">
      <incoming>sf1</incoming>
      <outgoing>sf2</outgoing>
    </serviceTask>

    <userTask id="showLoginResult" name="Результат авторизации"
              camunda:formKey="embedded:app:forms/auth-result.html"
              camunda:assignee="admin">
      <incoming>sf2</incoming>
      <outgoing>sf3</outgoing>
    </userTask>

    <endEvent id="end" name="Авторизован">
      <incoming>sf3</incoming>
    </endEvent>

    <sequenceFlow id="sf1" sourceRef="start" targetRef="loginUser"/>
    <sequenceFlow id="sf2" sourceRef="loginUser" targetRef="showLoginResult"/>
    <sequenceFlow id="sf3" sourceRef="showLoginResult" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="auth-login-process">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="160" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="loginUser_di" bpmnElement="loginUser">
        <omgdc:Bounds x="250" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="showLoginResult_di" bpmnElement="showLoginResult">
        <omgdc:Bounds x="410" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="570" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <omgdi:waypoint x="196" y="120"/>
        <omgdi:waypoint x="250" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <omgdi:waypoint x="350" y="120"/>
        <omgdi:waypoint x="410" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <omgdi:waypoint x="510" y="120"/>
        <omgdi:waypoint x="570" y="120"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
