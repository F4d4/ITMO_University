<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="MonetizationRequestDefinitions">

  <process id="monetization-request-process" name="Monetization Request Process" isExecutable="true">

    <startEvent id="startMonetization" name="Monetization Requested">
      <outgoing>flow_start_to_check</outgoing>
    </startEvent>

    <serviceTask id="checkEligibility" name="Check Monetization Eligibility"
                 camunda:delegateExpression="${checkMonetizationEligibilityDelegate}">
      <incoming>flow_start_to_check</incoming>
      <outgoing>flow_check_to_gateway</outgoing>
    </serviceTask>

    <exclusiveGateway id="eligibilityGateway" name="Eligible for Monetization?">
      <incoming>flow_check_to_gateway</incoming>
      <outgoing>flow_eligible</outgoing>
      <outgoing>flow_not_eligible</outgoing>
    </exclusiveGateway>

    <endEvent id="monetizationRejected" name="Monetization Rejected - Not Eligible">
      <incoming>flow_not_eligible</incoming>
    </endEvent>

    <userTask id="selectStrategy" name="Select Monetization Strategy"
              camunda:assignee="${uploaderId}"
              camunda:formKey="embedded:app:forms/monetization-request.html">
      <incoming>flow_eligible</incoming>
      <outgoing>flow_strategy_to_save</outgoing>
    </userTask>

    <serviceTask id="saveMonetization" name="Save Monetization Request"
                 camunda:delegateExpression="${saveMonetizationDelegate}">
      <incoming>flow_strategy_to_save</incoming>
      <outgoing>flow_save_to_end</outgoing>
    </serviceTask>

    <endEvent id="monetizationApproved" name="Monetization Approved">
      <incoming>flow_save_to_end</incoming>
    </endEvent>

    <sequenceFlow id="flow_start_to_check" sourceRef="startMonetization" targetRef="checkEligibility"/>
    <sequenceFlow id="flow_check_to_gateway" sourceRef="checkEligibility" targetRef="eligibilityGateway"/>
    <sequenceFlow id="flow_eligible" name="Eligible" sourceRef="eligibilityGateway" targetRef="selectStrategy">
      <conditionExpression xsi:type="tFormalExpression">${eligible == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_not_eligible" name="Not Eligible" sourceRef="eligibilityGateway" targetRef="monetizationRejected">
      <conditionExpression xsi:type="tFormalExpression">${eligible == false}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="flow_strategy_to_save" sourceRef="selectStrategy" targetRef="saveMonetization"/>
    <sequenceFlow id="flow_save_to_end" sourceRef="saveMonetization" targetRef="monetizationApproved"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="monetization-request-process">
      <bpmndi:BPMNShape id="startMonetization_di" bpmnElement="startMonetization">
        <omgdc:Bounds x="150" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="checkEligibility_di" bpmnElement="checkEligibility">
        <omgdc:Bounds x="240" y="160" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="eligibilityGateway_di" bpmnElement="eligibilityGateway" isMarkerVisible="true">
        <omgdc:Bounds x="400" y="175" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="selectStrategy_di" bpmnElement="selectStrategy">
        <omgdc:Bounds x="510" y="160" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="saveMonetization_di" bpmnElement="saveMonetization">
        <omgdc:Bounds x="670" y="160" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="monetizationApproved_di" bpmnElement="monetizationApproved">
        <omgdc:Bounds x="830" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="monetizationRejected_di" bpmnElement="monetizationRejected">
        <omgdc:Bounds x="407" y="320" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="flow_start_to_check_di" bpmnElement="flow_start_to_check">
        <omgdi:waypoint x="186" y="200"/>
        <omgdi:waypoint x="240" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_check_to_gateway_di" bpmnElement="flow_check_to_gateway">
        <omgdi:waypoint x="340" y="200"/>
        <omgdi:waypoint x="400" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_eligible_di" bpmnElement="flow_eligible">
        <omgdi:waypoint x="450" y="200"/>
        <omgdi:waypoint x="510" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_not_eligible_di" bpmnElement="flow_not_eligible">
        <omgdi:waypoint x="425" y="225"/>
        <omgdi:waypoint x="425" y="320"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_strategy_to_save_di" bpmnElement="flow_strategy_to_save">
        <omgdi:waypoint x="610" y="200"/>
        <omgdi:waypoint x="670" y="200"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="flow_save_to_end_di" bpmnElement="flow_save_to_end">
        <omgdi:waypoint x="770" y="200"/>
        <omgdi:waypoint x="830" y="200"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
