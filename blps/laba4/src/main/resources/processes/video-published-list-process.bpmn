<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="VideoPublishedListDefs">
  <process id="video-published-list-process" name="[GET] Опубликованные видео" isExecutable="true">

    <startEvent id="start" name="Начало">
      <outgoing>sf_start</outgoing>
    </startEvent>

    <serviceTask id="loadPublished" name="Загрузить опубликованные видео"
                 camunda:delegateExpression="${loadPublishedVideosDelegate}">
      <incoming>sf_start</incoming>
      <incoming>sf_refresh</incoming>
      <outgoing>sf_loaded</outgoing>
    </serviceTask>

    <userTask id="showPublishedList" name="Опубликованные видео"
              camunda:formKey="embedded:app:forms/published-videos-list.html"
              camunda:assignee="${assignee}">
      <incoming>sf_loaded</incoming>
      <outgoing>sf_to_gw</outgoing>
    </userTask>

    <exclusiveGateway id="refreshGw" name="Обновить?" default="sf_close">
      <incoming>sf_to_gw</incoming>
      <outgoing>sf_refresh</outgoing>
      <outgoing>sf_close</outgoing>
    </exclusiveGateway>

    <endEvent id="end" name="Просмотр завершён">
      <incoming>sf_close</incoming>
    </endEvent>

    <sequenceFlow id="sf_start" sourceRef="start" targetRef="loadPublished"/>
    <sequenceFlow id="sf_loaded" sourceRef="loadPublished" targetRef="showPublishedList"/>
    <sequenceFlow id="sf_to_gw" sourceRef="showPublishedList" targetRef="refreshGw"/>
    <sequenceFlow id="sf_refresh" name="Обновить" sourceRef="refreshGw" targetRef="loadPublished">
      <conditionExpression xsi:type="tFormalExpression">${refresh == true}</conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="sf_close" name="Закрыть" sourceRef="refreshGw" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="video-published-list-process">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="160" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="loadPublished_di" bpmnElement="loadPublished">
        <omgdc:Bounds x="250" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="showPublishedList_di" bpmnElement="showPublishedList">
        <omgdc:Bounds x="410" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="refreshGw_di" bpmnElement="refreshGw" isMarkerVisible="true">
        <omgdc:Bounds x="570" y="95" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="692" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf_start_di" bpmnElement="sf_start">
        <omgdi:waypoint x="196" y="120"/>
        <omgdi:waypoint x="250" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_loaded_di" bpmnElement="sf_loaded">
        <omgdi:waypoint x="350" y="120"/>
        <omgdi:waypoint x="410" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_to_gw_di" bpmnElement="sf_to_gw">
        <omgdi:waypoint x="510" y="120"/>
        <omgdi:waypoint x="570" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_close_di" bpmnElement="sf_close">
        <omgdi:waypoint x="620" y="120"/>
        <omgdi:waypoint x="692" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf_refresh_di" bpmnElement="sf_refresh">
        <omgdi:waypoint x="595" y="145"/>
        <omgdi:waypoint x="595" y="210"/>
        <omgdi:waypoint x="300" y="210"/>
        <omgdi:waypoint x="300" y="160"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
