<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="http://bpmn.io/schema/bpmn"
             id="AuthRegisterDefs">
  <process id="auth-register-process" name="[POST] Регистрация пользователя" isExecutable="true">

    <startEvent id="start" name="Начало регистрации">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="username" label="Имя пользователя" type="string">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="email" label="Email" type="string">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="password" label="Пароль" type="string">
            <camunda:validation>
              <camunda:constraint name="required"/>
            </camunda:validation>
          </camunda:formField>
          <camunda:formField id="role" label="Роль" type="enum" defaultValue="USER">
            <camunda:value id="USER" name="Пользователь"/>
            <camunda:value id="MODERATOR" name="Модератор"/>
          </camunda:formField>
        </camunda:formData>
      </extensionElements>
      <outgoing>sf1</outgoing>
    </startEvent>

    <serviceTask id="registerUser" name="Зарегистрировать пользователя"
                 camunda:delegateExpression="${registerUserDelegate}">
      <incoming>sf1</incoming>
      <outgoing>sf2</outgoing>
    </serviceTask>

    <userTask id="showAuthResult" name="Результат регистрации"
              camunda:assignee="admin">
      <extensionElements>
        <camunda:formData>
          <camunda:formField id="authResultMessage" label="Результат" type="string"/>
          <camunda:formField id="jwtToken" label="JWT-токен" type="string"/>
        </camunda:formData>
      </extensionElements>
      <incoming>sf2</incoming>
      <outgoing>sf3</outgoing>
    </userTask>

    <endEvent id="end" name="Зарегистрирован">
      <incoming>sf3</incoming>
    </endEvent>

    <sequenceFlow id="sf1" sourceRef="start" targetRef="registerUser"/>
    <sequenceFlow id="sf2" sourceRef="registerUser" targetRef="showAuthResult"/>
    <sequenceFlow id="sf3" sourceRef="showAuthResult" targetRef="end"/>

  </process>

  <bpmndi:BPMNDiagram id="diagram">
    <bpmndi:BPMNPlane id="plane" bpmnElement="auth-register-process">
      <bpmndi:BPMNShape id="start_di" bpmnElement="start">
        <omgdc:Bounds x="160" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="registerUser_di" bpmnElement="registerUser">
        <omgdc:Bounds x="250" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="showAuthResult_di" bpmnElement="showAuthResult">
        <omgdc:Bounds x="410" y="80" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="end_di" bpmnElement="end">
        <omgdc:Bounds x="570" y="102" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="sf1_di" bpmnElement="sf1">
        <omgdi:waypoint x="196" y="120"/>
        <omgdi:waypoint x="250" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf2_di" bpmnElement="sf2">
        <omgdi:waypoint x="350" y="120"/>
        <omgdi:waypoint x="410" y="120"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="sf3_di" bpmnElement="sf3">
        <omgdi:waypoint x="510" y="120"/>
        <omgdi:waypoint x="570" y="120"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
